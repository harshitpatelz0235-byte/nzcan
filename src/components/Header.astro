---
// src/components/Header.astro
import { getCollection } from 'astro:content';

const { country = 'nz' } = Astro.props;

// Dynamically fetch unique categories from the content collection
const allEntries = await getCollection(country as any);
const uniqueCategories = [...new Set(allEntries.map((entry: any) => entry.data.category))].sort();

const navLinks = uniqueCategories.map(cat => ({
  name: cat.charAt(0).toUpperCase() + cat.slice(1),
  href: `/${country}/${cat.toLowerCase().replace(/\s+/g, '-')}/`
}));

// Fallback if no entries found yet
const finalNavLinks = navLinks.length > 0 ? navLinks : [
  { name: 'Telecom', href: `/${country}/telecom/` },
  { name: 'Appliances', href: `/${country}/appliances/` },
];
---

<header class="sticky top-0 z-50 w-full border-b border-white/10 glass bg-background/70 backdrop-blur-xl">
  <div class="container mx-auto px-4 h-20 flex items-center justify-between">
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-11 h-11 bg-foreground text-background rounded-lg flex items-center justify-center font-black text-xl shadow-2xl group-hover:bg-primary group-hover:text-white transition-all duration-300">ED</div>
        <div class="flex flex-col -gap-1">
          <span class="text-xl font-black tracking-tighter text-foreground uppercase">ErrorDocs</span>
          <span class="text-[10px] uppercase font-bold tracking-[0.2em] text-foreground/40 leading-none">The Tech Rescue Hub</span>
        </div>
      </a>
      
      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-6">
        {finalNavLinks.map(link => (
          <a href={link.href} class="text-[10px] font-black uppercase tracking-widest text-foreground/50 hover:text-primary transition-all">
            {link.name}
          </a>
        ))}
      </nav>
    </div>

    <div class="flex items-center gap-6">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="relative w-12 h-6 rounded-full bg-foreground/10 border border-white/10 flex items-center px-1 transition-all hover:bg-foreground/20"
        aria-label="Toggle Theme"
      >
        <div id="toggle-circle" class="w-4 h-4 rounded-full bg-primary shadow-sm transition-transform duration-300 flex items-center justify-center overflow-hidden">
          <div id="sun-icon" class="w-2.5 h-2.5 text-white">☀️</div>
          <div id="moon-icon" class="hidden w-2.5 h-2.5 text-white">🌙</div>
        </div>
      </button>

      <!-- Geo-Toggle -->
      <div class="flex items-center bg-foreground/5 p-1 rounded-full border border-white/10 h-10 px-2 gap-1">
        <a 
          href="/nz/" 
          class={`flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold transition-all ${country === 'nz' ? 'bg-primary text-white shadow-md' : 'text-foreground/50 hover:text-foreground'}`}
        >
          🇳🇿 <span class="hidden sm:inline">NZ</span>
        </a>
        <a 
          href="/ca/" 
          class={`flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold transition-all ${country === 'ca' ? 'bg-primary text-white shadow-md' : 'text-foreground/50 hover:text-foreground'}`}
        >
          🇨🇦 <span class="hidden sm:inline">CA</span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-foreground/70 hover:text-primary transition-colors" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation Overlay -->
  <div id="mobile-menu" class="fixed inset-0 bg-background/95 backdrop-blur-xl z-[60] flex flex-col items-center justify-center gap-8 transition-all duration-300 opacity-0 pointer-events-none translate-y-4 lg:hidden">
    <button id="close-menu-btn" class="absolute top-6 right-6 p-2 text-foreground/50 hover:text-primary">
       <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    {finalNavLinks.map(link => (
      <a href={link.href} class="text-2xl font-black text-foreground hover:text-primary transition-colors tracking-tight uppercase italic">
        {link.name}
      </a>
    ))}
  </div>
</header>
