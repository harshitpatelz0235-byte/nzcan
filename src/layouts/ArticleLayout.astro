---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import InstantAnswer from '../components/InstantAnswer.astro';
import AdSenseBlock from '../components/AdSenseBlock.astro';

const { entry, country = 'nz' } = Astro.props;
const { title, description, author, lastUpdated, category, instantAnswer } = entry.data;

const formattedDate = typeof lastUpdated === 'string' 
	? new Date(lastUpdated).toLocaleDateString('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' })
	: lastUpdated.toLocaleDateString('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' });

const breadcrumbItems = [
	{ name: 'Home', href: '/' },
	{ name: country.toUpperCase(), href: `/${country}/` },
	{ name: category, href: `/${country}/${category.toLowerCase().replace(/\s+/g, '-')}/` },
	{ name: title, href: Astro.url.pathname }
];

const schema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [{
		"@type": "Question",
		"name": `How do I fix ${title}?`,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": instantAnswer || description
		}
	}]
});
---

<BaseLayout title={title} description={description} country={country} schema={schema}>
	<div id="progress-bar" class="fixed top-0 left-0 h-1 bg-primary z-[60] transition-all duration-300 w-0"></div>
	<Header country={country} />

	<main class="container mx-auto px-4 py-12 max-w-4xl">
		<Breadcrumbs items={breadcrumbItems} />

		<article class="animate-fade-in relative">
			<div class="flex items-center gap-2 mb-6">
				<span class="px-2 py-0.5 bg-foreground text-background text-[10px] font-black uppercase tracking-widest rounded">Technical Guide</span>
				<span class="text-foreground/30 text-[10px] font-bold uppercase tracking-widest tech-mono">Ref: FIX-{category.substring(0,3).toUpperCase()}</span>
			</div>

			<h1 class="text-5xl lg:text-7xl font-black mb-8 tracking-tighter leading-[0.9] text-foreground uppercase italic">
				{title}
			</h1>

			<div class="flex flex-wrap items-center gap-6 mb-12 py-6 border-y border-foreground/5 text-foreground/50 text-[10px] font-black uppercase tracking-widest">
				<div class="flex items-center gap-2">
					<span class="text-foreground/20">Author:</span>
					<span class="text-foreground">{author}</span>
				</div>
				<div class="flex items-center gap-2">
					<span class="text-foreground/20">Updated:</span>
					<span class="text-foreground tech-mono">{formattedDate}</span>
				</div>
				<div class="flex items-center gap-2">
					<span class="text-foreground/20">Status:</span>
					<span class="text-success">Verified Human Fix</span>
				</div>
			</div>

			{/* Quick Action Bar */}
			<div class="flex gap-4 mb-12">
				<button class="px-6 py-3 bg-primary text-white font-black uppercase text-xs tracking-widest rounded-lg shadow-[4px_4px_0px_0px_rgba(0,0,0,0.2)] hover:translate-x-0.5 hover:translate-y-0.5 transition-all">Print Fix</button>
				<button class="px-6 py-3 border border-foreground/10 font-black uppercase text-xs tracking-widest rounded-lg hover:bg-foreground hover:text-background transition-all">Copy Link</button>
			</div>

			{/* Safety Alert */}
			<div class="mb-12 p-6 bg-rose-500 text-white rounded-2xl shadow-[8px_8px_0px_0px_rgba(244,63,94,0.2)]">
				<div class="flex items-center gap-3 mb-2">
					<span class="text-xl">⚠️</span>
					<span class="font-black uppercase tracking-widest text-sm">Critical Safety Alert</span>
				</div>
				<p class="text-xs font-bold leading-relaxed opacity-90 uppercase tracking-tight">Always disconnect the main power source before attempting any hardware or appliance repair. Failure to do so can result in electrical shock or death.</p>
			</div>

			{instantAnswer && <InstantAnswer answer={instantAnswer} />}

			<AdSenseBlock slot="article-top" />

			<div class="prose prose-xl dark:prose-invert max-w-none prose-headings:font-black prose-headings:tracking-tighter prose-headings:uppercase prose-p:leading-relaxed prose-p:font-medium prose-a:text-primary prose-strong:text-foreground">
				<slot />
			</div>

			<AdSenseBlock slot="article-middle" />
			
			{/* Related Fixes (The Spiderweb) */}
			<div class="mt-20 p-8 rounded-3xl bg-primary/5 border border-primary/10">
				<h3 class="text-2xl font-bold mb-6">Related {category} Fixes</h3>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					<a href="#" class="block p-4 glass rounded-xl hover:border-primary/50 transition-colors">
						<span class="text-xs font-black uppercase tracking-widest text-primary mb-1 block">Next Fix</span>
						<span class="font-bold">Fisher & Paykel F1 Error Guide</span>
					</a>
					<a href="#" class="block p-4 glass rounded-xl hover:border-primary/50 transition-colors">
						<span class="text-xs font-black uppercase tracking-widest text-primary mb-1 block">Related</span>
						<span class="font-bold">How to Reset Any F&P Dishwasher</span>
					</a>
				</div>
			</div>
		</article>

		{/* Author Bio (E-E-A-T) */}
		<div class="mt-16 pt-16 border-t border-foreground/5 flex items-center gap-6">
			<div class="w-20 h-20 rounded-2xl premium-gradient flex items-center justify-center text-white text-3xl font-bold">
				{author[0]}
			</div>
			<div>
				<h4 class="text-xl font-bold mb-1">{author}</h4>
				<p class="text-foreground/60 leading-relaxed max-w-md">
					A former appliance technician with 15+ years of experience fixing local NZ and CA hardware. Dedicated to making tech less frustrating.
				</p>
			</div>
		</div>
	</main>

	<Footer />
</BaseLayout>

<script is:inline>
	document.addEventListener('scroll', () => {
		const progressBar = document.getElementById('progress-bar');
		if (!progressBar) return;
		
		const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
		const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
		const scrolled = (winScroll / height) * 100;
		progressBar.style.width = scrolled + "%";
	});
</script>

