---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const nzEntries = await getCollection('nz');
	const caEntries = await getCollection('ca');
	
	const allCategories = [
		...nzEntries.map(entry => ({ params: { country: 'nz', category: entry.id.split('/')[0] } })),
		...caEntries.map(entry => ({ params: { country: 'ca', category: entry.id.split('/')[0] } }))
	];

	// Deduplicate categories
	const uniqueCategories = Array.from(new Set(allCategories.map(c => JSON.stringify(c)))).map(s => JSON.parse(s));

	return uniqueCategories;
}

const { country, category } = Astro.params;
const allFixes = await getCollection(country as 'nz' | 'ca');
const categoryFixes = allFixes.filter(f => f.id.split('/')[0] === category);

const breadcrumbItems = [
	{ name: 'Home', href: '/' },
	{ name: country?.toUpperCase() || '', href: `/${country}/` },
	{ name: category ? category.charAt(0).toUpperCase() + category.slice(1).replace(/-/g, ' ') : '', href: `/${country}/${category}/` }
];
---

<BaseLayout 
	title={`${category?.toUpperCase().replace(/-/g, ' ')} Fixes | ${country?.toUpperCase()}`} 
	description={`Manual troubleshooting guides and fixes for ${category?.replace(/-/g, ' ')} in ${country?.toUpperCase()}.`}
	country={country as 'nz' | 'ca'}
>
	<Header country={country as 'nz' | 'ca'} />
	
	<main class="container mx-auto px-4 py-12 max-w-5xl">
		<Breadcrumbs items={breadcrumbItems} />

		<h1 class="text-4xl lg:text-6xl font-black mb-12 tracking-tight">
			{category?.replace(/-/g, ' ')} <span class="text-primary">Rescue Hub</span>
		</h1>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			{categoryFixes.map(fix => (
				<a href={`/${country}/${category}/${fix.id.split('/')[1] || fix.id}/`} class="group">
					<div class="glass p-6 rounded-2xl border border-white/5 hover:border-primary/20 transition-all">
						<span class="text-[10px] font-black uppercase tracking-widest text-primary mb-2 block">{fix.data.category}</span>
						<h3 class="text-xl font-bold mb-4 group-hover:text-primary transition-colors leading-tight">{fix.data.title}</h3>
						<p class="text-foreground/50 text-sm mb-6 line-clamp-2">{fix.data.description}</p>
						<span class="text-xs font-bold flex items-center gap-2 group-hover:translate-x-1 transition-transform">
							Read Fix Guide
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" x2="19" y1="12" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
						</span>
					</div>
				</a>
			))}
		</div>

		{categoryFixes.length === 0 && (
			<div class="text-center py-20 glass rounded-[2rem] border-dashed border-2">
				<p class="text-foreground/40 font-medium">No guides found in this silo yet. Check back soon!</p>
			</div>
		)}
	</main>

	<Footer />
</BaseLayout>
