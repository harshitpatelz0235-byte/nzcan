---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact HumanFix" description="Get in touch with the tech rescue team at HumanFix.">
	<Header country="nz" />
	<main class="container mx-auto px-4 py-32 max-w-2xl text-center">
		<h1 class="text-5xl font-black mb-12 tracking-tight">Contact <span class="text-primary text-gradient">Rescue Team</span></h1>
		
		<div class="glass p-12 rounded-[3rem] border border-white/10 shadow-3xl text-center">
			<div class="w-20 h-20 premium-gradient rounded-3xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-8 shadow-xl">
				<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
			</div>
			
			<h2 class="text-2xl font-bold mb-4">Email Us</h2>
			<p class="text-foreground/60 text-lg mb-8 leading-relaxed">
				Found a bug or have a tech rescue request? <br />
				We respond faster than a tech support bot.
			</p>
			
			<a href="mailto:support@humanfix.com" class="text-3xl font-black text-primary hover:scale-105 transition-transform inline-block underline decoration-4 underline-offset-8">
				support@humanfix.com
			</a>
		</div>

		<p class="mt-12 text-foreground/40 text-sm">
			Based in Auckland, NZ & Toronto, CA. <br />
			HumanFix: Manual fixes for the digital age.
		</p>
	</main>
	<Footer />
</BaseLayout>
